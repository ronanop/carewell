SITE_URL=https://www.carewellmedicalcentre.com
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Maps embed iframe src (Share → Embed). Overrides default preview if Sanity map URL is empty.
# NEXT_PUBLIC_CLINIC_MAP_EMBED_URL=https://www.google.com/maps/embed?pb=...
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_WRITE_TOKEN=
# Preview: must match secret used when opening Presentation preview from Studio
SANITY_PREVIEW_SECRET=
# Protect /studio route with HTTP Basic Auth (required in production)
STUDIO_BASIC_AUTH_USER=
STUDIO_BASIC_AUTH_PASS=

# Lead pipeline (optional — wire any combination)
GOOGLE_SHEETS_WEBHOOK_URL=
LEAD_WEBHOOK_URL=
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=
SENDGRID_TO_EMAIL=
LEAD_WHATSAPP_WEBHOOK_URL=

# Reviews snapshot (JSON string) — or implement Places API fetch in src/lib/reviews.ts
GOOGLE_PLACES_JSON=

# Skin scan (/skin-scan) — OpenAI vision (server only). Copy into .env.local; never commit real keys here.
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Optional: must be vision-capable for skin photos (default gpt-4o). Examples: gpt-4o, gpt-4o-mini — not gpt-3.5
OPENAI_SKIN_MODEL=
# Optional: custom API base (Azure OpenAI, proxy). Default https://api.openai.com/v1
# OPENAI_BASE_URL=https://api.openai.com/v1

# YouTube latest videos
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_ID=

# Analytics (also editable in Sanity siteSettings)
NEXT_PUBLIC_GTM_ID=
